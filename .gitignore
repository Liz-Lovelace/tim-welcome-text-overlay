# node_modules is ~680 MB and contains the bundled Chromium binary (>100 MB),
# which exceeds GitHub's per-file limit. Install via `npm ci` instead.
node_modules/

# Generated by `npm run prebundle` (and baked into the Docker image at build
# time). Always deterministic from src/ + public/, so not worth committing.
bundle/

# Ad-hoc Remotion render outputs.
out/

# OS / editor noise.
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Logs
npm-debug.log*
*.log
